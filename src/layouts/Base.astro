---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site, hours } from '../lib/site';

interface Props {
  title: string;
  description?: string;
  /** Path only, e.g. "/treatments/baby-botox". Defaults to current URL. */
  canonicalPath?: string;
  ogImage?: string;
  /** Extra JSON-LD objects to inject (FAQPage, MedicalProcedure, BreadcrumbList…). */
  jsonLd?: object[];
  /** Procedure offered on this page — linked from the clinic node as availableService. */
  availableService?: object;
  /** Keep utility pages (thank-you, 404) out of search indexes. */
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  canonicalPath,
  ogImage = '/assets/og-default.png',
  jsonLd = [],
  availableService,
  noindex = false,
} = Astro.props;

// Pages are built as directories (/about/index.html), so the served URL — and
// the sitemap entry — ends in a slash. Canonicals must match exactly.
const rawPath = canonicalPath ?? Astro.url.pathname;
const path = rawPath.endsWith('/') || /\.[a-z0-9]+$/i.test(rawPath) ? rawPath : `${rawPath}/`;
const canonical = new URL(path, site.url).href;
const ogImageUrl = new URL(ogImage, site.url).href;
const fullTitle = title.includes(site.name) ? title : `${title} | ${site.name}`;

// LocalBusiness schema injected on every page for local SEO / E-E-A-T.
const localBusiness = {
  '@context': 'https://schema.org',
  // MedicalClinic ⊂ MedicalBusiness ⊂ LocalBusiness — most specific type, and
  // the one that legitimately carries availableService.
  '@type': 'MedicalClinic',
  '@id': `${site.url}/#clinic`,
  name: site.legalName,
  description: site.description,
  url: site.url,
  telephone: '+447944242079',
  email: site.email,
  image: ogImageUrl,
  priceRange: '££',
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.locality,
    postalCode: site.address.postcode,
    addressCountry: site.address.country,
  },
  geo: { '@type': 'GeoCoordinates', latitude: site.geo.lat, longitude: site.geo.lng },
  hasMap: site.mapsUrl,
  currenciesAccepted: 'GBP',
  sameAs: Object.values(site.social),
  ...(availableService ? { availableService } : {}),
  /* No aggregateRating/review markup: Google ignores self-serving review
     schema on LocalBusiness pages and can issue manual actions for it.
     Reviews stay visible on-page via the Testimonials component. */
  openingHoursSpecification: hours
    .filter((h) => h.value !== 'Closed')
    .map((h) => {
      const [opens, closes] = h.value.split('–').map((s) => s.trim());
      return { '@type': 'OpeningHoursSpecification', dayOfWeek: h.day, opens, closes };
    }),
};
// WebSite node on the homepage only — tells Google (and AI crawlers) the
// site-wide name to display in results.
const webSite =
  path === '/'
    ? [{ '@context': 'https://schema.org', '@type': 'WebSite', name: site.name, url: site.url }]
    : [];
const schemas = [localBusiness, ...webSite, ...jsonLd];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#282d26" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.tagline}`} />
    <meta property="og:locale" content="en_GB" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Fonts (Newsreader · Hanken Grotesk · Spline Sans Mono) are self-hosted
         via @fontsource-variable imports in global.css. -->
    {schemas.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
