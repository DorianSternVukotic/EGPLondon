---
interface Props { items: { q: string; a: string }[]; heading?: string; }
const { items, heading = 'Frequently asked questions' } = Astro.props;
---
<section class="max-w-3xl mx-auto px-5 lg:px-6 py-16">
  <h2 class="font-semibold text-2xl md:text-3xl text-center mb-10">{heading}</h2>
  <div class="divide-y divide-beige-dark border-y border-beige-dark">
    {items.map((item) => (
      <details class="group py-5">
        <summary class="flex justify-between items-center gap-4 cursor-pointer list-none font-medium text-heading">
          <span>{item.q}</span>
          <svg class="shrink-0 transition-transform group-open:rotate-45 text-brand" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" />
          </svg>
        </summary>
        <p class="mt-3 text-ink/80 leading-relaxed">{item.a}</p>
      </details>
    ))}
  </div>
</section>
