---
import { getReviews } from '../lib/data';
interface Props { limit?: number; seed?: string; heading?: string; }
const { limit = 6, seed = '', heading = 'What our clients say' } = Astro.props;
// Prefer reviews with a written comment; longest first for richer cards.
const all = getReviews()
  .filter((r) => r.comment)
  .sort((a, b) => b.comment.length - a.comment.length);
// Rotate the visible window by seed so different pages surface different reviews.
let s = 0;
for (let i = 0; i < seed.length; i++) s = (s * 31 + seed.charCodeAt(i)) >>> 0;
const start = all.length ? s % all.length : 0;
const reviews = Array.from({ length: Math.min(limit, all.length) }, (_, i) => all[(start + i) % all.length]);
if (reviews.length === 0) return null;
const clamp = (s: string) => (s.length > 240 ? s.slice(0, 237).trimEnd() + '…' : s);

// Placeholder avatar per reviewer — stable per name across builds.
const faces = Array.from({ length: 12 }, (_, i) => `/assets/avatars/face${i + 1}.jpg`);
const avatarFor = (name: string) => {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) >>> 0;
  return faces[h % faces.length];
};
---
<section class="bg-lichen/50 border-y border-beige-dark/60">
  <div class="max-w-6xl mx-auto px-5 lg:px-6 py-20 md:py-24">
    <div class="max-w-2xl mb-12">
      <p class="rule-label mb-4 max-w-xs"><span>In their words</span></p>
      <h2 class="font-display text-4xl md:text-5xl">{heading}</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {reviews.map((r) => (
        <figure class="bg-paper border border-beige-dark/70 p-7 flex flex-col">
          <div class="flex gap-1 mb-4" aria-label={`${r.rating} out of 5 stars`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill={i < r.rating ? '#a98a5e' : 'none'} stroke="#a98a5e" stroke-width="1.5">
                <polygon points="12 2 15 9 22 9 17 14 19 21 12 17 5 21 7 14 2 9 9 9" />
              </svg>
            ))}
          </div>
          {r.title && <h3 class="font-display text-lg text-heading mb-2">{r.title}</h3>}
          <blockquote class="text-sm text-ink/75 leading-relaxed flex-1">“{clamp(r.comment)}”</blockquote>
          <figcaption class="mt-5 pt-4 border-t border-beige-dark/60 flex items-center gap-3">
            <img src={avatarFor(r.name)} alt={r.name} loading="lazy" width="40" height="40" class="w-10 h-10 rounded-full object-cover bg-lichen shrink-0" />
            <span class="record text-2xs uppercase tracking-[0.18em] text-brand">{r.name}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
