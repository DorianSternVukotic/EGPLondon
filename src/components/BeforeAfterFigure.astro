---
/* Inline before/after pair for the body of treatment & condition articles.
   Only renders real, matching cases: pages resolve one via galleryCaseFor()
   in src/lib/data.ts and pass its photos explicitly — there is deliberately
   no fallback imagery, so a page without a corresponding case shows nothing. */
interface Props {
  before: string;
  after: string;
  caption?: string;
}
const { before, after, caption } = Astro.props;
---
<figure class="my-9 bg-paper border border-beige-dark/70">
  <div class="grid grid-cols-2">
    <div class="relative aspect-[3/4]">
      <img src={before} alt="Before treatment" loading="lazy" width="540" height="720" class="w-full h-full object-cover" />
      <span class="absolute top-3 left-3 record text-2xs uppercase tracking-[0.2em] bg-paper text-ink px-2.5 py-1">Before</span>
    </div>
    <div class="relative aspect-[3/4] border-l border-paper">
      <img src={after} alt="After treatment" loading="lazy" width="540" height="720" class="w-full h-full object-cover" />
      <span class="absolute top-3 left-3 record text-2xs uppercase tracking-[0.2em] bg-brand text-paper px-2.5 py-1">After</span>
    </div>
  </div>
  <figcaption class="p-4 record text-2xs uppercase tracking-[0.18em] text-stone">
    {caption ?? 'Before & after · Individual results vary'}
  </figcaption>
</figure>
