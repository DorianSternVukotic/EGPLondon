---
import { site, hours } from '../lib/site';

const year = 2026;
const quickLinks = [
  { label: 'Treatments', href: '/treatments' },
  { label: 'Conditions We Treat', href: '/conditions' },
  { label: 'About Us', href: '/about' },
  { label: 'Find Us', href: '/find-us' },
  { label: 'Book an Appointment', href: '/book' },
];
const socials = Object.entries(site.social);
---

<footer class="bg-forest text-cream/90">
  <div class="max-w-6xl mx-auto px-5 lg:px-6 py-16 grid gap-12 md:grid-cols-4 border-t border-cream/10">
    <div class="md:col-span-1">
      <img src="/assets/logo-white.png" alt={site.name} width="652" height="91" class="h-7 w-auto mb-5" />
      <p class="text-sm leading-relaxed text-cream/70">{site.tagline}.</p>
      <div class="flex gap-4 mt-5">
        {socials.map(([name, url]) => (
          <a href={url} aria-label={name} class="text-cream/70 hover:text-cream capitalize text-sm">
            {name}
          </a>
        ))}
      </div>
    </div>

    <div>
      <h3 class="eyebrow !text-cream/60 mb-4">Explore</h3>
      <ul class="space-y-2.5 text-sm">
        {quickLinks.map((l) => (
          <li><a href={l.href} class="text-cream/80 hover:text-cream">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="eyebrow !text-cream/60 mb-4">Visit</h3>
      <address class="not-italic text-sm text-cream/80 leading-relaxed">
        {site.address.street}<br />
        {site.address.locality} {site.address.postcode}<br />
        <a href={site.phoneHref} class="hover:text-cream">{site.phone}</a><br />
        <a href={`mailto:${site.email}`} class="hover:text-cream">{site.email}</a>
      </address>
    </div>

    <div>
      <h3 class="eyebrow !text-cream/60 mb-4">Opening Hours</h3>
      <ul class="space-y-1.5 text-sm text-cream/80">
        {hours.map((h) => (
          <li class="flex justify-between gap-4">
            <span>{h.day}</span><span class="text-cream/60">{h.value}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="border-t border-cream/15">
    <div class="max-w-6xl mx-auto px-5 lg:px-6 py-6 flex flex-col sm:flex-row justify-between gap-3 text-xs text-cream/55">
      <p>© {year} {site.legalName}. All rights reserved.</p>
      <p class="max-w-xl sm:text-right">
        Information on this site is educational and not a substitute for professional medical advice. A consultation is required before treatment.
      </p>
    </div>
  </div>
</footer>
