---
import type { Condition } from '../lib/data';
interface Props { condition: Condition; }
const { condition: c } = Astro.props;

// Source data carries no per-condition imagery, so map each concern to a
// representative clinic photo deterministically (stable per slug, varied across
// the grid). Face concerns draw from the face/skin set, body from body/laser.
const facePhotos = [
  '/assets/demo/cat-face.webp',
  '/assets/demo/cat-skin.jpg',
  '/assets/demo/cat-fillers.jpg',
];
const bodyPhotos = [
  '/assets/demo/cat-body.jpg',
  '/assets/demo/cat-laser.jpg',
  '/assets/demo/cat-skin.jpg',
];
const pool = c.group === 'face' ? facePhotos : bodyPhotos;
let h = 0;
for (const ch of c.slug) h = (h * 31 + ch.charCodeAt(0)) >>> 0;
const photo = pool[h % pool.length];

const area = c.group === 'face' ? 'Face' : 'Body';
const pills = c.treatments.slice(0, 3);
---
<a
  href={`/conditions/${c.slug}`}
  class="group block bg-paper rounded-card overflow-hidden border border-beige-dark/70 hover:border-honey/60 hover:shadow-lg transition-all"
>
  <div class="aspect-[4/3] overflow-hidden bg-lichen">
    <img
      src={photo}
      alt={`${c.title} — ${area}`}
      loading="lazy"
      decoding="async"
      width="600"
      height="450"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
    />
  </div>
  <div class="p-6">
    <p class="record text-[0.6rem] uppercase tracking-[0.2em] text-honey-ink">{area}</p>
    <h3 class="font-display text-2xl text-heading mt-1 group-hover:text-brand transition-colors">{c.title}</h3>
    <p class="mt-2 text-sm text-ink/70 leading-relaxed line-clamp-2">{c.description}</p>
    {pills.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-2">
        {pills.map((t) => (
          <li class="record text-[0.62rem] px-3 py-1 rounded-full bg-lichen/70 border border-beige-dark/70 text-ink/75">{t.label}</li>
        ))}
      </ul>
    )}
  </div>
</a>
