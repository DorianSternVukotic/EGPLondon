---
import { getGallery } from '../lib/data';
interface Props { limit?: number; }
const { limit = 4 } = Astro.props;
const cases = getGallery().slice(0, limit);
if (cases.length === 0) return null;
---
<section class="max-w-6xl mx-auto px-5 lg:px-6 py-20 md:py-24">
  <div class="max-w-2xl mb-12">
    <p class="rule-label mb-4 max-w-xs"><span>Real results</span></p>
    <h2 class="font-display text-4xl md:text-5xl">Before &amp; after</h2>
    <p class="mt-4 text-ink/70 leading-relaxed">A selection of results from our clinic. Individual results vary; every plan is tailored at consultation.</p>
  </div>
  <div class="grid sm:grid-cols-2 gap-6">
    {cases.map((c) => (
      <figure class="bg-paper border border-beige-dark/70">
        <div class="grid grid-cols-2">
          <div class="relative aspect-[3/4]">
            <img src={c.before} alt={`Before — ${c.title}`} loading="lazy" width="540" height="720" class="w-full h-full object-cover" />
            <span class="absolute top-3 left-3 record text-2xs uppercase tracking-[0.2em] bg-paper text-ink px-2.5 py-1">Before</span>
          </div>
          <div class="relative aspect-[3/4] border-l border-paper">
            <img src={c.after} alt={`After — ${c.title}`} loading="lazy" width="540" height="720" class="w-full h-full object-cover" />
            <span class="absolute top-3 left-3 record text-2xs uppercase tracking-[0.2em] bg-brand text-paper px-2.5 py-1">After</span>
          </div>
        </div>
        <figcaption class="p-5 flex items-baseline justify-between gap-4">
          <h3 class="font-display text-lg text-heading">{c.title}</h3>
          {c.projectType && <p class="record text-2xs uppercase tracking-[0.18em] text-stone shrink-0">{c.projectType}</p>}
        </figcaption>
      </figure>
    ))}
  </div>
  <p class="record text-2xs uppercase tracking-[0.16em] text-stone mt-8">Photographs published with written client consent · Unretouched</p>
</section>
