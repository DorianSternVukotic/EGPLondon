---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProblemFaceNav from '../../components/ProblemFaceNav.astro';
import { treatmentCategories, getTreatments, formatPrice, formatDuration } from '../../lib/data';
import { mediaForSlug, cartoonForTreatment } from '../../lib/treatmentMedia';
import { breadcrumbList } from '../../lib/schema';

const cats = treatmentCategories();
const total = getTreatments().length;
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Treatments', href: '/treatments' }];
const jsonLd = [breadcrumbList(crumbs)];
const anchor = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---
<Base
  title="Treatments | EGP Aesthetics London"
  description={`Explore all ${total} non-surgical and biostimulating treatments at EGP Aesthetics London — Profhilo, Polynucleotides, PRP, skin boosters, anti-wrinkle and body contouring, all doctor-led.`}
  canonicalPath="/treatments"
  jsonLd={jsonLd}
>
  <section class="max-w-6xl mx-auto px-5 lg:px-6 pt-6 pb-10">
    <Breadcrumbs items={crumbs} />
    <div class="mt-7 max-w-2xl">
      <p class="rule-label mb-4 max-w-xs"><span>The menu</span></p>
      <h1 class="font-display text-5xl md:text-6xl tracking-[-0.02em]">Treatments</h1>
      <p class="mt-5 text-ink/75 leading-relaxed">
        {total} treatments spanning face, skin, body, hair and advanced non-surgical science — from Profhilo and
        Polynucleotides to ultrasound and radiofrequency tightening. Choose a category and explore, or begin with a free
        discovery consultation and digital skin analysis and we’ll guide you to the least invasive option for your goals.
      </p>
    </div>
    <nav class="mt-9 flex flex-wrap gap-x-5 gap-y-2 record text-[0.62rem] uppercase tracking-[0.18em]">
      {cats.map((cat) => (
        <a href={`#${anchor(cat.name)}`} class="text-stone hover:text-brand border-b border-transparent hover:border-honey pb-1 transition-colors">
          {cat.name} <span class="text-honey-ink">{cat.items.length}</span>
        </a>
      ))}
    </nav>
  </section>

  <ProblemFaceNav />

  {cats.map((cat) => {
    const meta = mediaForSlug(cat.items[0]?.categorySlug);
    return (
      <section id={anchor(cat.name)} class="max-w-6xl mx-auto px-5 lg:px-6 py-10 md:py-12 scroll-mt-24">
        {/* Part 1 — image + title (taller) */}
        <div class="relative overflow-hidden min-h-[300px] md:min-h-[360px] flex items-end">
          <img src={meta.photo} alt={`${cat.name} treatments at EGP Aesthetics`} loading="lazy" class="absolute inset-0 w-full h-full object-cover object-[center_30%]" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest/90 via-forest/45 to-transparent"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-forest/70 to-transparent"></div>
          <div class="relative p-7 md:p-10">
            <p class="eyebrow text-honey-soft mb-2">{cat.items.length} treatments</p>
            <h2 class="font-display text-3xl md:text-4xl text-paper capitalize">{cat.name.toLowerCase()}</h2>
            <p class="mt-2 text-paper/80 text-sm md:text-base max-w-md leading-relaxed">{meta.blurb}</p>
          </div>
        </div>

        {/* Part 2 — two columns of tall cards, each built around its cartoon line-art.
             The illustration is the centerpiece (full-bleed, mix-blend on a soft
             sage field); a paper scrim down the bottom keeps the overlaid name legible. */}
        <div class="grid sm:grid-cols-2 gap-px bg-beige-dark/60 border border-beige-dark/60 mt-px">
          {cat.items.map((t) => (
            <a
              href={`/treatments/${t.slug}`}
              class="group relative overflow-hidden bg-gradient-to-br from-lichen/45 via-paper to-paper min-h-[300px] md:min-h-[360px] flex flex-col justify-end"
            >
              {/* Cartoon centerpiece — large, right-weighted, blended onto the field */}
              <img
                src={cartoonForTreatment(t)}
                alt=""
                aria-hidden="true"
                class="pointer-events-none absolute right-0 top-1/2 -translate-y-1/2 h-[116%] w-auto max-w-[78%] object-contain object-right mix-blend-multiply transition-transform duration-700 ease-out group-hover:scale-[1.045]"
              />
              {/* Legibility scrims — bottom band for the text, faint left wash for balance */}
              <div class="absolute inset-0 bg-gradient-to-t from-paper from-[6%] via-paper/85 via-[34%] to-transparent to-[66%] pointer-events-none"></div>
              <div class="absolute inset-0 bg-gradient-to-r from-paper/70 via-transparent to-transparent pointer-events-none"></div>
              {/* Hover wash of warmth */}
              <div class="absolute inset-0 bg-honey/0 group-hover:bg-honey/[0.04] transition-colors duration-500 pointer-events-none"></div>

              <div class="relative p-6 md:p-7">
                <h3 class="font-display text-2xl md:text-[1.7rem] leading-[1.12] text-heading group-hover:text-brand transition-colors max-w-[15ch]">{t.name}</h3>
                <div class="mt-4 flex items-center gap-4 record text-xs">
                  <span class="text-brand uppercase tracking-[0.12em]">{t.price === 0 ? 'Free' : `From ${formatPrice(t.discountedPrice ?? t.price)}`}</span>
                  {t.duration ? <span class="text-stone tabular-nums">{formatDuration(t.duration)}</span> : null}
                  <span class="ml-auto text-honey-ink opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" aria-hidden="true">→</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    );
  })}

  <div class="py-6"></div>
  <CtaBand />
</Base>
