---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { treatmentCategories, getTreatments, formatPrice, formatDuration } from '../../lib/data';
import { mediaForSlug, cartoonFor } from '../../lib/treatmentMedia';
import { breadcrumbList } from '../../lib/schema';

const cats = treatmentCategories();
const total = getTreatments().length;
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Treatments', href: '/treatments' }];
const jsonLd = [breadcrumbList(crumbs)];
const anchor = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---
<Base
  title="Treatments | EGP Aesthetics London"
  description={`Explore all ${total} aesthetic treatments at EGP Aesthetics London — anti-wrinkle, dermal fillers, skin, body contouring and regenerative treatments.`}
  canonicalPath="/treatments"
  jsonLd={jsonLd}
>
  <section class="max-w-6xl mx-auto px-5 lg:px-6 pt-6 pb-10">
    <Breadcrumbs items={crumbs} />
    <div class="mt-7 max-w-2xl">
      <p class="rule-label mb-4 max-w-xs"><span>The menu</span></p>
      <h1 class="font-display text-5xl md:text-6xl tracking-[-0.02em]">Treatments</h1>
      <p class="mt-5 text-ink/75 leading-relaxed">
        {total} expertly delivered treatments across face, body and regenerative medicine. Choose a category, then
        explore the treatments within — or start with a free discovery consultation and we’ll guide you.
      </p>
    </div>
    <nav class="mt-9 flex flex-wrap gap-x-5 gap-y-2 record text-[0.62rem] uppercase tracking-[0.18em]">
      {cats.map((cat) => (
        <a href={`#${anchor(cat.name)}`} class="text-stone hover:text-brand border-b border-transparent hover:border-honey pb-1 transition-colors">
          {cat.name} <span class="text-honey-ink">{cat.items.length}</span>
        </a>
      ))}
    </nav>
  </section>

  {cats.map((cat) => {
    const meta = mediaForSlug(cat.items[0]?.categorySlug);
    return (
      <section id={anchor(cat.name)} class="max-w-6xl mx-auto px-5 lg:px-6 py-10 md:py-12 scroll-mt-24">
        {/* Part 1 — image + title (taller) */}
        <div class="relative overflow-hidden min-h-[300px] md:min-h-[360px] flex items-end">
          <img src={meta.photo} alt={`${cat.name} treatments at EGP Aesthetics`} loading="lazy" class="absolute inset-0 w-full h-full object-cover object-[center_30%]" />
          <div class="absolute inset-0 bg-gradient-to-t from-forest/90 via-forest/45 to-transparent"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-forest/70 to-transparent"></div>
          <div class="relative p-7 md:p-10">
            <p class="eyebrow text-honey-soft mb-2">{cat.items.length} treatments</p>
            <h2 class="font-display text-3xl md:text-4xl text-paper capitalize">{cat.name.toLowerCase()}</h2>
            <p class="mt-2 text-paper/80 text-sm md:text-base max-w-md leading-relaxed">{meta.blurb}</p>
          </div>
        </div>

        {/* Part 2 — sub-treatments, cartoon-outline background per item (randomized) */}
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-beige-dark/60 border border-beige-dark/60 mt-px">
          {cat.items.map((t) => (
            <a
              href={`/treatments/${t.slug}`}
              class="group relative overflow-hidden bg-paper p-6 min-h-[152px] flex flex-col justify-between"
            >
              <img src={cartoonFor(t.slug)} alt="" aria-hidden="true" class="pointer-events-none absolute -right-3 inset-y-0 h-full w-auto max-w-[52%] object-contain object-right mix-blend-multiply opacity-90 group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 bg-gradient-to-r from-paper via-paper/85 to-transparent pointer-events-none"></div>
              <h3 class="relative font-display text-lg leading-snug text-heading group-hover:text-brand transition-colors pr-16">{t.name}</h3>
              <div class="relative flex items-center justify-between record text-xs mt-4 pr-16">
                <span class="text-brand uppercase tracking-[0.12em]">{t.price === 0 ? 'Free' : `From ${formatPrice(t.discountedPrice ?? t.price)}`}</span>
                {t.duration ? <span class="text-stone tabular-nums">{formatDuration(t.duration)}</span> : null}
              </div>
            </a>
          ))}
        </div>
      </section>
    );
  })}

  <div class="py-6"></div>
  <CtaBand />
</Base>
