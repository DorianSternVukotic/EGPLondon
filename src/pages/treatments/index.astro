---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ProblemFaceNav from '../../components/ProblemFaceNav.astro';
import { treatmentCategories, getTreatments, formatPrice, formatDuration } from '../../lib/data';
import { mediaForSlug, cartoonsForTreatments, consultationCartoon, medallionFocus, fallbackFocus } from '../../lib/treatmentMedia';
import { breadcrumbList } from '../../lib/schema';

const cats = treatmentCategories();
const total = getTreatments().length;
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Treatments', href: '/treatments' }];
const jsonLd = [breadcrumbList(crumbs)];
const anchor = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-');
---
<Base
  title="Treatments | EGP Aesthetics London"
  description={`Explore all ${total} non-surgical and biostimulating treatments at EGP Aesthetics London — Profhilo, Polynucleotides, PRP, skin boosters, anti-wrinkle and body contouring, all doctor-led.`}
  canonicalPath="/treatments"
  jsonLd={jsonLd}
>
  <section class="max-w-6xl mx-auto px-5 lg:px-6 pt-6 pb-10">
    <Breadcrumbs items={crumbs} />
    <div class="mt-7 max-w-2xl">
      <p class="rule-label mb-4 max-w-xs"><span>The menu</span></p>
      <h1 class="font-display text-5xl md:text-6xl tracking-[-0.02em]">Treatments</h1>
      <p class="mt-5 text-ink/75 leading-relaxed">
        {total} treatments spanning face, skin, body, hair and advanced non-surgical science — from Profhilo and
        Polynucleotides to ultrasound and radiofrequency tightening. Choose a category and explore, or begin with a free
        discovery consultation and digital skin analysis and we’ll guide you to the least invasive option for your goals.
      </p>
    </div>
    <nav class="mt-9 flex flex-wrap gap-x-5 gap-y-2 record text-2xs uppercase tracking-[0.18em]">
      {cats.map((cat) => (
        <a href={`#${anchor(cat.name)}`} class="text-stone hover:text-brand border-b border-transparent hover:border-honey pb-1 transition-colors">
          {cat.name} <span class="text-honey-ink">{cat.items.length}</span>
        </a>
      ))}
    </nav>
  </section>

  <ProblemFaceNav />

  {cats.map((cat, ci) => {
    const meta = mediaForSlug(cat.items[0]?.categorySlug);
    const cartoons = cartoonsForTreatments(cat.items);
    const foci = cartoons.map((c) => medallionFocus[c] ?? fallbackFocus);
    const flip = ci % 2 === 1;
    return (
      <section id={anchor(cat.name)} class="max-w-6xl mx-auto px-5 lg:px-6 py-7 md:py-9 scroll-mt-24">
        {/* One framed split per category — the homepage "Featured treatments"
             layout, grown up: an editorial photo panel carries the category
             (sticky on desktop, alternating sides), and the treatments read as
             a menu of compact rows so the section scales from 1 to 17 items. */}
        {/* No overflow-hidden here — it would become the sticky panel's scrollport and break pinning.
             The column template flips with the photo so the menu always keeps the wide column. */}
        <div class:list={['grid gap-px bg-beige-dark/60 border border-beige-dark/60', flip ? 'lg:grid-cols-[1.4fr_0.85fr]' : 'lg:grid-cols-[0.85fr_1.4fr]']}>
          {/* Photo panel — sticky beside long lists, banner on mobile. Long
               categories pin for several viewport-heights, so their sticky
               column fills the whole viewport: the photo flexes to take most
               of it and a consultation card (with the category line-art as a
               watermark) occupies the bottom — no bare paper trailing the
               photo while it follows the scroll. */}
          <div class:list={['relative bg-paper', flip && 'lg:order-last']}>
            <div class:list={[
              'relative h-[230px] md:h-[280px] lg:sticky lg:top-[5.25rem] lg:flex lg:flex-col',
              cat.items.length <= 2
                ? 'lg:h-[min(calc(100svh_-_6.5rem),19rem)]'
                : cat.items.length <= 4
                  ? 'lg:h-[min(calc(100svh_-_6.5rem),26rem)]'
                  : 'lg:h-[calc(100svh_-_6.5rem)]',
            ]}>
              <div class="relative h-full lg:h-auto lg:flex-1 lg:min-h-0">
                <img src={meta.photo} alt={`${cat.name} treatments at EGP Aesthetics`} loading="lazy" class="absolute inset-0 w-full h-full object-cover object-[center_30%]" />
                <div class="absolute inset-0 bg-gradient-to-t from-forest/95 via-forest/55 to-transparent"></div>
                <div class="absolute bottom-0 inset-x-0 p-6 md:p-8">
                  <p class="eyebrow text-honey-soft mb-2">{cat.items.length} {cat.items.length === 1 ? 'treatment' : 'treatments'}</p>
                  <h2 class="font-display text-3xl md:text-4xl text-paper capitalize">{cat.name.toLowerCase()}</h2>
                  <p class="mt-2 text-paper/80 text-sm max-w-sm leading-relaxed hidden md:block">{meta.blurb}</p>
                </div>
              </div>
              {cat.items.length > 4 ? (
                <a href="/book" class="group/cta relative hidden lg:block shrink-0 overflow-hidden border-t border-beige-dark/60 bg-lichen/40 px-6 py-5">
                  <img
                    src={consultationCartoon}
                    alt=""
                    aria-hidden="true"
                    loading="lazy"
                    class="pointer-events-none absolute -right-3 top-1/2 -translate-y-1/2 h-[165%] w-auto max-w-[52%] object-contain object-right mix-blend-multiply opacity-70 transition-transform duration-700 ease-out group-hover/cta:scale-[1.05]"
                  />
                  <p class="relative eyebrow mb-1.5">Not sure where to start?</p>
                  <p class="relative font-display text-lg leading-snug text-heading group-hover/cta:text-brand transition-colors max-w-[17ch]">
                    Book a free discovery consultation <span class="text-honey-ink" aria-hidden="true">→</span>
                  </p>
                </a>
              ) : null}
            </div>
          </div>

          {/* The menu — one row per treatment: cartoon medallion, name + one-line
               whisper of the description, price + duration in the record layer. */}
          <div class="relative bg-paper flex flex-col justify-center">
            <ol class="divide-y divide-beige-dark/50">
              {cat.items.map((t, i) => (
                <li>
                  <a
                    href={`/treatments/${t.slug}`}
                    class="group grid grid-cols-[auto_1fr_auto] items-center gap-x-4 md:gap-x-6 px-4 md:px-6 py-3 md:py-3.5 hover:bg-lichen/40 transition-colors"
                  >
                    {/* The problem vignette — the line-art is the row's anchor, so it gets
                         real size; a soft per-art zoom (origins from medallionFocus, damped
                         because the larger frame already shows most of the sheet) keeps the
                         subject filling the frame, and the inner wrapper adds a hover zoom
                         the inline transform on the img would otherwise swallow. */}
                    <span class="relative h-20 w-20 md:h-28 md:w-28 shrink-0 rounded-card overflow-hidden bg-gradient-to-br from-lichen/90 to-paper border border-beige-dark/60 group-hover:border-honey/60 transition-colors">
                      <span class="absolute inset-0 transition-transform duration-700 ease-out group-hover:scale-[1.06]">
                        <img src={cartoons[i]} alt="" aria-hidden="true" loading="lazy" class="absolute inset-0 h-full w-full object-cover mix-blend-multiply" style={`transform:scale(${1 + (foci[i].scale - 1) * 0.6});transform-origin:${foci[i].origin};`} />
                      </span>
                    </span>
                    <span class="min-w-0">
                      <h3 class="font-display text-lg md:text-[1.45rem] leading-snug text-heading group-hover:text-brand transition-colors">
                        {t.name}
                        <span class="inline-block ml-2 text-honey-ink text-base opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" aria-hidden="true">→</span>
                      </h3>
                      {t.description ? <p class="hidden md:line-clamp-2 text-sm text-stone leading-snug mt-1 max-w-md">{t.description}</p> : null}
                    </span>
                    <span class="text-right shrink-0">
                      <span class="block record text-2xs uppercase tracking-[0.12em] text-brand">{t.price === 0 ? 'Free' : `From ${formatPrice(t.discountedPrice ?? t.price)}`}</span>
                      {t.duration ? <span class="block record text-2xs text-stone tabular-nums mt-0.5">{formatDuration(t.duration)}</span> : null}
                    </span>
                  </a>
                </li>
              ))}
            </ol>
          </div>
        </div>
      </section>
    );
  })}

  <div class="py-6"></div>
  <CtaBand />
</Base>
