---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../lib/site';

const values = [
  { label: 'Principle', t: 'Non-surgical by design', d: 'We favour advanced biostimulating treatments that support your skin’s own renewal, keeping intervention — and downtime — to a minimum.' },
  { label: 'Principle', t: 'Honesty above all', d: 'No pressure and no trend-chasing. If a treatment isn’t right for you, we’ll say so.' },
  { label: 'Principle', t: 'Artistry with restraint', d: 'Refreshed, balanced and natural. We enhance the features you already have rather than rebuild them.' },
];
---
<Base
  title="About Us | EGP Aesthetics London"
  description="Meet EGP Aesthetics London — a doctor-led clinic founded by two sisters on advanced non-surgical science, honesty and natural-looking results."
  canonicalPath="/about"
>
  <section class="max-w-3xl mx-auto px-5 lg:px-6 pt-16 md:pt-24 text-center">
    <p class="rule-label justify-center mb-5 max-w-[9rem] mx-auto"><span>Our story</span></p>
    <h1 class="font-display text-5xl md:text-6xl leading-[1.04] tracking-[-0.02em]">A more considered kind of <span class="living">aesthetics</span></h1>
    <p class="mt-7 text-lg text-ink/75 leading-relaxed">
      We are two sisters — both medical doctors — who founded EGP as the antidote to a mass market built on the same
      few syringes and a single, over-filled look. We believe aesthetic medicine should be non-surgical wherever
      possible, led by science rather than trends, and tailored to the individual in front of us.
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-5 lg:px-6 py-16">
    <img src="/assets/photos/hero-1.webp" alt="The founders of EGP Aesthetics London" width="1600" height="900" class="aspect-[16/9] w-full object-cover object-top" />
  </section>

  <section class="max-w-6xl mx-auto px-5 lg:px-6 pb-8">
    <div class="grid md:grid-cols-3 gap-10">
      {values.map((v) => (
        <div class="border-t border-beige-dark pt-5">
          <p class="record text-[0.62rem] uppercase tracking-[0.2em] text-honey-ink mb-3">{v.label}</p>
          <h3 class="font-display text-xl mb-2">{v.t}</h3>
          <p class="text-ink/70 text-sm leading-relaxed">{v.d}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-5 lg:px-6 py-12 prose-egp text-center">
    <p>
      Combining medical training with a measured, science-first approach, we deliver results in a calm, private
      setting in the heart of London. Whether it’s your first treatment or ongoing care, you’ll always be met with
      honesty, warmth and clinical rigour — and never sold something you don’t need.
    </p>
  </section>

  <CtaBand title="Come and meet us" text={`Visit us at ${site.address.street}, ${site.address.locality}. Book a complimentary discovery consultation and digital skin analysis.`} />
</Base>
