---
import Base from '../layouts/Base.astro';
import ConcernCategoryCard from '../components/ConcernCategoryCard.astro';
import CtaBand from '../components/CtaBand.astro';
import Faq from '../components/Faq.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import Testimonials from '../components/Testimonials.astro';
import TreatmentShowcase from '../components/TreatmentShowcase.astro';
import ClinicLocation from '../components/ClinicLocation.astro';
import { site, credentials } from '../lib/site';
import { concernTaxonomy, getTreatments, getConditions, treatmentCategories, formatPrice } from '../lib/data';
import { mediaForSlug, cartoonForCategory, conditionPhoto } from '../lib/treatmentMedia';
import { faqPage } from '../lib/schema';

// Three most-requested categories, each shown as image+title + a few sub-treatments.
const featuredCats = treatmentCategories()
  .slice()
  .sort((a, b) => b.items.length - a.items.length)
  .slice(0, 3);
const { face: faceCats, body: bodyCats, prevention } = concernTaxonomy();
const concernCats = [...faceCats, ...bodyCats, prevention];
/* One representative photo per category tile — candidates ranked by how many
   of the category's concerns map to them, then de-duplicated across the grid
   so no two tiles share an image. */
const usedPhotos = new Set<string>();
const catPhotos = concernCats.map((cat) => {
  const freq = new Map<string, number>();
  for (const c of cat.items) {
    const p = conditionPhoto(c);
    freq.set(p, (freq.get(p) ?? 0) + 1);
  }
  const candidates = [...freq.entries()].sort((a, b) => b[1] - a[1]).map(([p]) => p);
  const photo = candidates.find((p) => !usedPhotos.has(p)) ?? candidates[0] ?? '/assets/conditions/face.jpg';
  usedPhotos.add(photo);
  return photo;
});
const treatmentCount = getTreatments().length;
const conditionCount = getConditions().length;

/* The two patient groups Galina flagged as growing fastest — spotlighted
   after "Why EGP" as narrative bands rather than navigation. */
const spotlights = [
  {
    label: 'After rapid weight loss',
    title: 'Lost weight quickly?',
    copy: 'GLP-1 medications and rapid weight loss can leave skin behind — deflated in the face, loose on the body. We rebuild volume and tighten skin without surgery.',
    links: [
      { label: 'Loose skin after weight loss', href: '/conditions#weight-loss-skin' },
      { label: 'Facial ageing after weight loss', href: '/conditions/facial-ageing-after-weight-loss' },
    ],
  },
  {
    label: 'Prevention',
    title: 'Nothing wrong yet?',
    copy: 'High-definition cameras, video calls and social feeds have made us all more skin-aware. Preventative, low-intervention treatments protect skin quality before lines and laxity set in.',
    links: [
      { label: 'Prevention & skin awareness', href: '/conditions#prevention' },
      { label: 'Early signs of ageing', href: '/conditions/early-signs-of-ageing' },
    ],
  },
];

const values = [
  { label: 'Approach', t: 'Non-surgical first', d: 'We reach for advanced biostimulating science — Profhilo, Polynucleotides, PRP, Exosomes, Sculptra — and turn to filler only when it’s genuinely the right tool.' },
  { label: 'Practitioners', t: 'Medically led', d: 'Every plan is designed and delivered by two qualified doctors — never rushed, never delegated to a technician.' },
  { label: 'Standard', t: 'Fully insured & certified', d: 'Medical-grade products, sterile protocols and complete clinical accountability behind every treatment.' },
  { label: 'Counsel', t: 'Honest advice', d: 'No pressure and no trend-chasing. If a treatment isn’t right for you, we’ll tell you — and explain why.' },
  { label: 'Outcome', t: 'Natural results', d: 'Refreshed and balanced, never the overfilled, ‘done’ look. We work with the features you already have.' },
  { label: 'Science', t: 'Cutting-edge, evidence-based', d: 'We stay current with regenerative and device-based medicine so your options reflect what genuinely works — not what’s trending online.' },
];

const faqs = [
  { q: 'Do I need a consultation before treatment?', a: 'Yes — every treatment begins with a consultation so we can assess your skin and recommend the safest, most effective plan. Discovery consultations, including a digital skin analysis, are complimentary.' },
  { q: 'Are your treatments non-surgical?', a: 'Yes. Our focus is advanced non-surgical and biostimulating treatments — from Profhilo and Polynucleotides to ultrasound and radiofrequency tightening — designed to support your skin’s own renewal with no surgery and minimal downtime.' },
  { q: 'Do you offer dermal and lip fillers?', a: 'We do, but we treat filler as one tool among many rather than the default answer. We’ll only recommend it when it’s clinically the right choice for your goals — and often there’s a more regenerative option.' },
  { q: 'What makes EGP different from a high-street clinic?', a: 'Every treatment is planned and delivered by two medical doctors, using cutting-edge non-surgical science rather than a one-size-fits-all menu. The clinic is fully insured, evidence-led, and honest about what will — and won’t — help.' },
];
const jsonLd = [faqPage(faqs)];
---
<Base title={`${site.name} London — Non-Surgical, Doctor-Led Aesthetics`} jsonLd={jsonLd} canonicalPath="/">
  <!-- Hero — full-screen founders -->
  <section class="relative min-h-[calc(100svh-4rem)] md:min-h-[calc(100svh-4.5rem)] flex items-end overflow-hidden">
    <img
      src="/assets/photos/hero-1.webp"
      alt="The founders of EGP Aesthetics London — two sisters, both doctors"
      width="1920" height="2880" fetchpriority="high"
      class="absolute inset-0 w-full h-full object-cover object-[center_18%]"
    />
    <!-- Scrims: vertical carries the whole lower text band dark enough for the eyebrow + headline,
         horizontal anchors the bottom-left text. -->
    <div class="absolute inset-0 bg-gradient-to-t from-forest from-10% via-forest/70 via-60% to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-forest/70 via-transparent to-transparent"></div>
    <div class="relative w-full max-w-6xl mx-auto px-5 lg:px-6 pb-14 md:pb-20 [text-shadow:0_1px_2px_rgba(20,24,18,0.9),0_3px_22px_rgba(20,24,18,0.55)]">
      <p class="eyebrow text-honey-soft mb-5">Founded by two doctors · Two sisters</p>
      <h1 class="font-display text-paper text-[clamp(2.75rem,8vw,6rem)] leading-[0.98] tracking-[-0.02em] max-w-3xl">
        Advanced aesthetics, without the <span class="italic font-medium text-honey-soft">scalpel</span>.
      </h1>
      <p class="mt-6 text-lg text-paper/85 leading-relaxed max-w-xl">
        Non-surgical, doctor-led treatments that work with your biology — biostimulators, polynucleotides and regenerative science, not a default syringe of filler.
      </p>
      <div class="mt-9 flex flex-col sm:flex-row gap-3">
        <a href="/book?treatment=Free%20Discovery%20Consultation" class="bg-paper text-forest px-8 py-4 text-sm uppercase tracking-[0.14em] font-medium text-center hover:bg-honey-soft transition-colors">
          Book a free consultation
        </a>
        <a href="/about" class="border border-paper/40 text-paper px-8 py-4 text-sm uppercase tracking-[0.14em] font-medium text-center hover:bg-paper/10 transition-colors">
          Meet your doctors
        </a>
      </div>
    </div>
  </section>

  <!-- Signature: the clinical-record strip (the proof layer).
       Mobile = 2×2 hairline grid (gap-px reveals the divider colour); md = single row with
       vertical dividers, first cell flush to the gutter. -->
  <div class="border-b border-beige-dark/70 bg-paper">
    <div class="max-w-6xl mx-auto px-5 lg:px-6">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-px bg-beige-dark/60 md:gap-0 md:bg-transparent md:divide-x md:divide-beige-dark/60">
        {credentials.map((c) => (
          <div class="bg-paper px-4 md:px-6 md:first:pl-0 py-5">
            <dt class="record text-2xs uppercase tracking-[0.2em] text-stone">{c.label}</dt>
            <dd class="font-display text-2xl md:text-[1.7rem] text-heading mt-1.5">{c.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </div>

  <!-- Meet the founders — the un-copyable asset (archetype ③) -->
  <section class="max-w-6xl mx-auto px-5 lg:px-6 py-20 md:py-28 grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
    <div class="order-last lg:order-first">
      <img src="/assets/photos/about-hero.webp" alt="The two founding doctors of EGP Aesthetics" loading="lazy" width="1200" height="1800" class="w-full aspect-[4/5] object-cover object-top" />
    </div>
    <div>
      <p class="rule-label mb-5 max-w-xs"><span>Your doctors</span></p>
      <h2 class="font-display text-4xl md:text-5xl leading-[1.05]">Two sisters.<br />Two doctors.<br />One <span class="living">standard</span>.</h2>
      <p class="mt-6 text-ink/75 leading-relaxed max-w-md">
        EGP was founded by two sisters — both medical doctors — who built the clinic they wished existed: medically led,
        unhurried, and free of pressure to over-treat. Every plan is designed and delivered by them, drawing on advanced
        non-surgical and biostimulating treatments rather than the off-the-shelf approach of the high street.
      </p>
      <dl class="mt-8 grid grid-cols-2 gap-x-6 gap-y-5 max-w-md">
        {[
          { k: 'Medically qualified', v: 'Doctor-led care' },
          { k: 'Technology-led', v: 'Biostimulation & devices' },
          { k: 'Founder-delivered', v: 'Seen by the sisters' },
          { k: 'Honest by default', v: 'No pressure, no trends' },
        ].map((f) => (
          <div class="border-t border-beige-dark pt-3">
            <dt class="record text-2xs uppercase tracking-[0.18em] text-honey-ink">{f.k}</dt>
            <dd class="text-sm text-ink/75 mt-1">{f.v}</dd>
          </div>
        ))}
      </dl>
      <a href="/about" class="inline-block mt-9 record text-2xs uppercase tracking-[0.18em] text-brand hover:text-honey-ink border-b border-honey/50 pb-1 transition-colors">
        Read their story →
      </a>
    </div>
  </section>

  <!-- Philosophy thesis — bold sage-dominant surface -->
  <section class="bg-forest text-paper/90">
    <div class="max-w-5xl mx-auto px-5 lg:px-6 py-20 md:py-28">
      <p class="rule-label text-honey-soft mb-9"><span>The thesis</span></p>
      <p class="font-display text-[clamp(1.6rem,3.6vw,2.6rem)] leading-[1.25] tracking-[-0.01em] text-paper">
        Most of the market chases a single look with the same few products. We do the opposite — we read your skin, then
        choose from the most advanced non-surgical science available, so the result is
        <span class="italic text-honey-soft">unmistakably you</span>, only better rested.
      </p>
      <a href="/about" class="inline-block mt-10 record text-2xs uppercase tracking-[0.18em] text-paper/70 hover:text-paper border-b border-honey/50 pb-1 transition-colors">
        Read our philosophy →
      </a>
    </div>
  </section>

  <!-- Featured treatments — image+title per category, then sub-treatments with cartoon line-art -->
  <section class="max-w-6xl mx-auto px-5 lg:px-6 py-20">
    <div class="flex items-end justify-between mb-10 gap-4">
      <div>
        <p class="rule-label mb-4 max-w-xs"><span>Most requested</span></p>
        <h2 class="font-display text-4xl md:text-5xl">Featured treatments</h2>
      </div>
      <a href="/treatments" class="hidden sm:inline record text-2xs uppercase tracking-[0.15em] text-brand hover:text-honey-ink shrink-0 transition-colors">All {treatmentCount} →</a>
    </div>

    <div class="space-y-6">
      {featuredCats.map((cat) => {
        const media = mediaForSlug(cat.items[0]?.categorySlug);
        const cartoon = cartoonForCategory(cat.name);
        const items = cat.items.slice(0, 6);
        return (
          <div class="grid md:grid-cols-[0.85fr_1.4fr] border border-beige-dark/60 bg-paper overflow-hidden">
            {/* Image + title (taller) */}
            <div class="relative min-h-[260px] md:min-h-[380px]">
              <img src={media.photo} alt={`${cat.name} treatments at EGP Aesthetics`} loading="lazy" class="absolute inset-0 w-full h-full object-cover object-[center_30%]" />
              <div class="absolute inset-0 bg-gradient-to-t from-forest/90 via-forest/45 to-transparent"></div>
              <div class="absolute bottom-0 inset-x-0 p-6 md:p-8">
                <p class="eyebrow text-honey-soft mb-2">{cat.items.length} treatments</p>
                <h3 class="font-display text-3xl md:text-4xl text-paper capitalize">{cat.name.toLowerCase()}</h3>
                <p class="mt-2 text-paper/80 text-sm max-w-xs leading-relaxed hidden md:block">{media.blurb}</p>
              </div>
            </div>

            {/* List — one cartoon behind the whole list */}
            <div class="relative overflow-hidden p-6 md:p-8 flex flex-col justify-center">
              <img src={cartoon} alt="" aria-hidden="true" class="pointer-events-none absolute -right-8 top-1/2 -translate-y-1/2 h-[125%] w-auto max-w-[60%] object-contain object-right mix-blend-multiply opacity-70" />
              <div class="absolute inset-0 bg-gradient-to-r from-paper via-paper/70 to-paper/20 pointer-events-none"></div>
              <ul class="relative grid sm:grid-cols-2 gap-x-8">
                {items.map((t) => (
                  <li class="border-b border-beige-dark/50">
                    <a href={`/treatments/${t.slug}`} class="group flex items-baseline justify-between gap-3 py-3">
                      <span class="font-display text-base md:text-lg text-heading group-hover:text-brand transition-colors">{t.name}</span>
                      <span class="record text-2xs text-stone group-hover:text-honey-ink whitespace-nowrap transition-colors">{t.price === 0 ? 'Free' : `£${formatPrice(t.discountedPrice ?? t.price).replace('£', '')}`}</span>
                    </a>
                  </li>
                ))}
              </ul>
              <a href="/treatments" class="relative mt-5 record text-2xs uppercase tracking-[0.18em] text-brand hover:text-honey-ink border-b border-honey/50 pb-1 self-start transition-colors">View all {cat.name.toLowerCase()} →</a>
            </div>
          </div>
        );
      })}
    </div>
    <a href="/treatments" class="sm:hidden block text-center mt-8 record text-2xs uppercase tracking-[0.15em] text-brand">All treatments →</a>
  </section>

  <!-- By area — photo-led showcase (comparison counterpart to Featured treatments) -->
  <TreatmentShowcase />

  <!-- Conditions -->
  <section class="bg-lichen/50 border-y border-beige-dark/60">
    <div class="max-w-6xl mx-auto px-5 lg:px-6 py-20">
      <div class="max-w-2xl mb-10">
        <p class="rule-label mb-4 max-w-xs"><span>Start with your concern</span></p>
        <h2 class="font-display text-4xl md:text-5xl">Explore by concern</h2>
        <p class="mt-4 text-ink/70 leading-relaxed">Not sure which treatment you need? Begin with what you’d like to change — we’ll match it to the most appropriate, least invasive approach.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {concernCats.map((cat, i) => <ConcernCategoryCard category={cat} photo={catPhotos[i]} />)}
      </div>
      <div class="mt-9">
        <a href="/conditions" class="record text-2xs uppercase tracking-[0.15em] text-brand hover:text-honey-ink transition-colors">All {conditionCount} concerns →</a>
      </div>
    </div>
  </section>

  <!-- Why choose us -->
  <section class="max-w-6xl mx-auto px-5 lg:px-6 py-20 md:py-24">
    <div class="max-w-2xl mb-14">
      <p class="rule-label mb-4 max-w-xs"><span>Why EGP</span></p>
      <h2 class="font-display text-4xl md:text-5xl">The premium, medical alternative</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-12 gap-y-12">
      {values.map((v) => (
        <div class="border-t border-beige-dark pt-5">
          <p class="record text-2xs uppercase tracking-[0.2em] text-honey-ink mb-3">{v.label}</p>
          <h3 class="font-display text-xl mb-2">{v.t}</h3>
          <p class="text-ink/70 text-sm leading-relaxed">{v.d}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Growth audiences — the two patient groups from Galina's concern taxonomy,
       framed as narrative rather than navigation (the tiles above cover that) -->
  <section class="bg-lichen/30 border-y border-beige-dark/60">
    <div class="max-w-6xl mx-auto px-5 lg:px-6 py-16 md:py-20">
      <div class="max-w-2xl mb-12">
        <p class="rule-label mb-4 max-w-xs"><span>Growing patient groups</span></p>
        <h2 class="font-display text-4xl md:text-5xl">Two reasons people find us now</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        {spotlights.map((s) => (
          <div class="bg-paper border border-beige-dark/70 p-8 md:p-10 flex flex-col">
            <p class="record text-2xs uppercase tracking-[0.2em] text-honey-ink mb-3">{s.label}</p>
            <h3 class="font-display text-3xl md:text-4xl">{s.title}</h3>
            <p class="mt-4 text-ink/70 leading-relaxed">{s.copy}</p>
            <ul class="mt-auto pt-8">
              {s.links.map((l) => (
                <li class="border-t border-beige-dark/50">
                  <a href={l.href} class="group flex items-baseline justify-between gap-4 py-3.5">
                    <span class="font-display text-lg text-heading group-hover:text-brand transition-colors">{l.label}</span>
                    <span class="record text-2xs text-stone group-hover:text-honey-ink transition-colors" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <BeforeAfter />
  <Testimonials />
  <Faq items={faqs} />
  <ClinicLocation />
  <CtaBand />
</Base>
