---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Faq from '../../components/Faq.astro';
import ConditionCard from '../../components/ConditionCard.astro';
import BeforeAfterFigure from '../../components/BeforeAfterFigure.astro';
import Testimonials from '../../components/Testimonials.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getConditions, getCondition, formatPrice } from '../../lib/data';
import { conditionPhoto } from '../../lib/treatmentMedia';
import { breadcrumbList, faqPage } from '../../lib/schema';
import { site } from '../../lib/site';

export function getStaticPaths() {
  return getConditions().map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const c = getCondition(slug!)!;
const related = getConditions().filter((x) => x.group === c.group && x.slug !== c.slug).slice(0, 4);

const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Conditions', href: '/conditions' },
  { name: c.title, href: `/conditions/${c.slug}` },
];

const faqs = [
  { q: `What causes ${c.title.toLowerCase()}?`, a: `${c.title} can have several contributing factors, from ageing and genetics to lifestyle and sun exposure. At your consultation we assess the underlying cause so we can recommend the most effective approach.` },
  { q: `How is ${c.title.toLowerCase()} treated at EGP Aesthetics?`, a: `We tailor treatment to you. Recommended options${c.treatments.length ? ` include ${c.treatments.map((t) => t.label).slice(0, 3).join(', ')}` : ''}. Your practitioner will design a personalised plan at your consultation.` },
  { q: `How many sessions will I need?`, a: `This depends on the treatment and your individual response. Some treatments deliver results after a single session, while others work best as a short course. We’ll set clear expectations at your consultation.` },
  { q: `Is treatment suitable for me?`, a: `Suitability depends on your medical history and goals, which we review at your complimentary consultation. We’ll always give you honest advice.` },
];

const metaDesc = `${c.title} treatment in London at EGP Aesthetics. ${c.description}. Book a free consultation to find the right approach for you.`;

const medicalCondition = {
  '@context': 'https://schema.org',
  '@type': 'MedicalCondition',
  name: c.title,
  description: c.description,
  url: new URL(`/conditions/${c.slug}`, site.url).href,
  possibleTreatment: c.treatments.map((t) => ({ '@type': 'MedicalTherapy', name: t.label })),
};
const jsonLd = [breadcrumbList(crumbs), faqPage(faqs), medicalCondition];
---
<Base
  title={`${c.title} Treatment London | EGP Aesthetics`}
  description={metaDesc.slice(0, 160)}
  canonicalPath={`/conditions/${c.slug}`}
  jsonLd={jsonLd}
>
  <section class="border-b border-beige-dark/60">
    <div class="max-w-6xl mx-auto px-5 lg:px-6 pt-6 pb-14 md:pb-16">
      <Breadcrumbs items={crumbs} />
      <div class="grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-16 items-start mt-7">
        <div>
          <p class="eyebrow mb-4">Concern · {c.category}</p>
          <h1 class="font-display text-4xl md:text-6xl leading-[1.04] tracking-[-0.02em]">{c.title}</h1>
          <p class="mt-6 text-lg text-ink/75 leading-relaxed max-w-xl">{c.description}.</p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <a href="/book" class="bg-brand text-paper px-8 py-4 text-sm uppercase tracking-[0.14em] font-medium text-center hover:bg-brand-dark transition-colors">
              Book a consultation
            </a>
            <a href="/treatments" class="border border-brand/25 text-brand px-8 py-4 text-sm uppercase tracking-[0.14em] font-medium text-center hover:bg-brand/5 transition-colors">
              Browse treatments
            </a>
          </div>
          <p class="mt-7 record text-2xs uppercase tracking-[0.18em] text-stone">
            Reviewed by the EGP medical team · Last updated June 2026
          </p>
        </div>

        <!-- Cross-link record: the treatments that address this concern -->
        {c.treatments.length > 0 && (
          <div class="bg-lichen/60 border border-beige-dark/70 order-first lg:order-last">
            <p class="rule-label px-6 pt-6 mb-4"><span>How we treat it</span></p>
            <ul class="px-6 pb-6">
              {c.treatments.map((t) => (
                <li class="border-b border-beige-dark/50 last:border-0">
                  <a href={t.slug ? `/treatments/${t.slug}` : '/treatments'} class="group flex items-baseline justify-between gap-4 py-3.5">
                    <span class="font-display text-lg text-heading group-hover:text-brand transition-colors">{t.label}</span>
                    {t.price != null && <span class="record text-2xs text-stone group-hover:text-honey-ink whitespace-nowrap transition-colors">From {formatPrice(t.price)}</span>}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Condition image -->
  <figure class="max-w-6xl mx-auto px-5 lg:px-6 pt-10">
    <div class="relative aspect-[16/7] md:aspect-[16/6] overflow-hidden bg-lichen">
      <img src={conditionPhoto(c)} alt={`${c.title} — visual reference`} loading="lazy" width="1600" height="700" class="w-full h-full object-cover" />
    </div>
  </figure>

  <section class="max-w-3xl mx-auto px-5 lg:px-6 py-14 prose-egp">
    <h2>About {c.title.toLowerCase()}</h2>
    <p>
      {c.description}. It’s one of the most common concerns we help with at EGP Aesthetics London. Because every case is
      different, we begin with a thorough assessment to understand the underlying cause before recommending treatment.
    </p>
    <h2>Results you can expect</h2>
    <p>
      With the right plan, {c.title.toLowerCase()} can be visibly improved. The example below illustrates the kind of
      natural-looking change our non-surgical, science-led approach aims for — results vary from person to person.
    </p>
    <BeforeAfterFigure seed={c.slug} caption={`Illustrative before & after · ${c.title}`} />
    <h2>Why treat it?</h2>
    <p>
      Addressing {c.title.toLowerCase()} can restore confidence and help you feel like yourself again. Our approach is
      non-surgical and natural-looking — we aim to improve the concern while keeping your features balanced and
      authentic.
    </p>
  </section>

  <Faq items={faqs} heading={`${c.title} — your questions answered`} />

  {related.length > 0 && (
    <section class="max-w-6xl mx-auto px-5 lg:px-6 py-12">
      <h2 class="font-semibold text-2xl md:text-3xl mb-8">Related concerns</h2>
      <div class="grid sm:grid-cols-2 gap-4">
        {related.map((r) => <ConditionCard condition={r} />)}
      </div>
    </section>
  )}

  <Testimonials limit={3} seed={c.slug} heading="What our clients say" />

  <CtaBand title={`Concerned about ${c.title.toLowerCase()}?`} />
</Base>
