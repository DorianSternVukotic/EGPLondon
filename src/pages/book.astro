---
import Base from '../layouts/Base.astro';
import BookingForm from '../components/BookingForm.astro';
import { site, hours } from '../lib/site';
---
<Base
  title="Book an Appointment"
  description="Request your appointment at EGP Aesthetics London. Send us an enquiry and our team will confirm your slot by phone or email."
  canonicalPath="/book"
>
  <section class="max-w-5xl mx-auto px-5 lg:px-6 py-14 md:py-20">
    <div class="grid lg:grid-cols-5 gap-10 lg:gap-16">
      <div class="lg:col-span-3">
        <p class="rule-label mb-4 max-w-[10rem]"><span>Book now</span></p>
        <h1 class="font-display text-5xl md:text-6xl tracking-[-0.02em]">Request your appointment</h1>
        <p class="mt-5 text-ink/75 leading-relaxed max-w-xl">
          Tell us a little about what you’re looking for and your preferred timing. Our team will be in touch to
          confirm your appointment. Not sure where to start? Book a free discovery consultation.
        </p>
        <div class="mt-8 bg-paper border border-beige-dark/70 p-6 md:p-8">
          <BookingForm />
        </div>
      </div>

      <aside class="lg:col-span-2 space-y-5">
        <div class="bg-forest text-paper p-7">
          <p class="rule-label text-honey-soft mb-4 max-w-[14rem]"><span>Free consultation</span></p>
          <p class="font-display text-xl leading-snug text-paper">New here? Your first discovery consultation is free.</p>
          <p class="text-paper/70 text-sm mt-2 leading-relaxed">
            A relaxed conversation about your skin and goals — including a digital skin analysis, with no obligation to
            book treatment.
          </p>
          <a
            href="/book?treatment=Free%20Discovery%20Consultation"
            class="inline-block mt-4 record text-2xs uppercase tracking-[0.16em] text-honey-soft hover:text-paper underline decoration-paper/30 underline-offset-4 transition-colors"
          >
            Request a free consultation →
          </a>
        </div>
        <div class="bg-lichen/50 border border-beige-dark/60 p-7">
          <p class="rule-label mb-4 max-w-[10rem]"><span>Prefer to talk?</span></p>
          <ul class="space-y-2 record text-sm">
            <li><a href={site.phoneHref} class="text-brand hover:text-honey-ink transition-colors">{site.phone}</a></li>
            <li><a href={site.whatsappHref} class="text-brand hover:text-honey-ink transition-colors">WhatsApp us</a></li>
            <li><a href={`mailto:${site.email}`} class="text-brand hover:text-honey-ink transition-colors break-all">{site.email}</a></li>
          </ul>
        </div>
        <div class="bg-lichen/50 border border-beige-dark/60 p-7">
          <p class="rule-label mb-4 max-w-[10rem]"><span>Opening hours</span></p>
          <ul class="space-y-0 text-sm text-ink/80">
            {hours.map((h) => (
              <li class="flex justify-between gap-4 border-b border-beige-dark/50 py-2 last:border-0"><span>{h.day}</span><span class="record text-2xs text-stone">{h.value}</span></li>
            ))}
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <script>
    // Static build: the "?treatment=" context from "Book this treatment" CTAs
    // must be applied client-side.
    const wanted = new URLSearchParams(location.search).get('treatment');
    const field = document.getElementById('bf-treatment') as HTMLInputElement | null;
    if (wanted && field && !field.value) field.value = wanted;
  </script>
</Base>
