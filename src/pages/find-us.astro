---
import Base from '../layouts/Base.astro';
import BookingForm from '../components/BookingForm.astro';
import { site, hours } from '../lib/site';

const mapEmbed = `https://www.google.com/maps?q=${encodeURIComponent(`${site.address.street}, ${site.address.locality} ${site.address.postcode}`)}&output=embed`;
---
<Base
  title="Find Us | EGP Aesthetics London"
  description={`Visit EGP Aesthetics at ${site.address.street}, ${site.address.locality} ${site.address.postcode}. Opening hours, parking and transport.`}
  canonicalPath="/find-us"
>
  <section class="max-w-6xl mx-auto px-5 lg:px-6 pt-14 pb-10">
    <p class="rule-label mb-4 max-w-xs"><span>Visit us</span></p>
    <h1 class="font-display text-5xl md:text-6xl tracking-[-0.02em]">Find us in London</h1>
    <p class="mt-5 text-ink/75 max-w-xl leading-relaxed">
      We’re on Wandsworth Road, a short walk from Clapham Common. Here’s everything you need to plan your visit.
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-5 lg:px-6 pb-16 grid lg:grid-cols-2 gap-10">
    <div>
      <div class="overflow-hidden border border-beige-dark/60 aspect-[4/3]">
        <iframe src={mapEmbed} title="Map to EGP Aesthetics" width="100%" height="100%" style="border:0" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
      <a href={site.mapsUrl} class="inline-block mt-4 record text-xs uppercase tracking-[0.16em] text-brand hover:text-honey-ink transition-colors">Get directions →</a>
    </div>

    <div class="space-y-8">
      <div>
        <p class="rule-label mb-3 max-w-[10rem]"><span>Address</span></p>
        <address class="not-italic font-display text-xl text-heading leading-relaxed">
          {site.address.street}<br />{site.address.locality} {site.address.postcode}
        </address>
        <div class="mt-3 record text-xs space-x-4">
          <a href={site.phoneHref} class="text-brand hover:text-honey-ink transition-colors">{site.phone}</a>
          <a href={`mailto:${site.email}`} class="text-brand hover:text-honey-ink transition-colors">{site.email}</a>
        </div>
      </div>
      <div>
        <p class="rule-label mb-3 max-w-[12rem]"><span>Opening hours</span></p>
        <ul class="space-y-0 text-sm text-ink/80 max-w-xs">
          {hours.map((h) => (
            <li class="flex justify-between gap-4 border-b border-beige-dark/50 py-2"><span>{h.day}</span><span class="record text-xs text-stone">{h.value}</span></li>
          ))}
        </ul>
      </div>
      <div class="grid sm:grid-cols-2 gap-6 text-sm">
        <div>
          <h3 class="font-display text-lg mb-1.5">Getting here</h3>
          <p class="text-ink/70 leading-relaxed">Clapham Common (Northern line) ~10 min walk. Buses 87 & 88 stop nearby.</p>
        </div>
        <div>
          <h3 class="font-display text-lg mb-1.5">Parking</h3>
          <p class="text-ink/70 leading-relaxed">Pay & display on The Chase and Victoria Rise. Car parks 3–5 min away.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-lichen/50 border-y border-beige-dark/60">
    <div class="max-w-3xl mx-auto px-5 lg:px-6 py-20">
      <div class="text-center mb-9">
        <p class="rule-label justify-center mb-4 max-w-[12rem] mx-auto"><span>Get in touch</span></p>
        <h2 class="font-display text-3xl md:text-4xl">Send us a message</h2>
      </div>
      <div class="bg-paper border border-beige-dark/70 p-6 md:p-9">
        <BookingForm />
      </div>
    </div>
  </section>
</Base>
