---
import Base from '../layouts/Base.astro';
import { site } from '../lib/site';
---
<Base title="Thank You" description="Your enquiry has been received." canonicalPath="/thank-you">
  <section class="max-w-xl mx-auto px-5 lg:px-6 py-28 text-center">
    <div class="size-16 mx-auto rounded-full bg-brand/10 flex items-center justify-center mb-7">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#a98a5e" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <p class="rule-label justify-center mb-5 max-w-[10rem] mx-auto"><span>Received</span></p>
    <h1 class="font-display text-4xl md:text-5xl">Thank you — we’ve got it</h1>
    <p class="mt-5 text-ink/75 leading-relaxed">
      Your enquiry is on its way to our team. We’ll be in touch shortly to confirm your appointment. For anything
      urgent, call us on <a href={site.phoneHref} class="text-brand underline decoration-honey-soft underline-offset-2">{site.phone}</a>.
    </p>
    <a href="/" class="inline-block mt-9 bg-brand text-paper px-8 py-4 text-sm uppercase tracking-[0.14em] font-medium hover:bg-brand-dark transition-colors">
      Back to home
    </a>
  </section>
</Base>
